PORSCHE_EMAIL=your-my-porsche-email@example.com
PORSCHE_PASSWORD=your-password

# Default request mode for overview endpoints:
# stored  = cached app/backend data, faster and gentler
# current = wake the car for fresher data
PORSCHE_OVERVIEW_MODE=stored

# Token cache inside the mounted data volume
PORSCHE_TOKEN_FILE=/app/data/token.json

# Host port published by docker compose
# Host port for docker-compose (not used on Render — Render sets PORT automatically)
HOST_PORT=8060
